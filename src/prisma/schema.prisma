datasource db {
  provider = "sqlite"
  url      = "file:/app/database/dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          Int       @id @default(autoincrement())
  telegramId  String    @unique
  username    String?
  firstName   String?
  lastName    String?
  balance         Float     @default(0.0)
  referralBalance Float     @default(0.0)
  referredById    Int?
  referredBy      User?     @relation("Referrals", fields: [referredById], references: [id])
  referrals       User[]    @relation("Referrals")
  isBanned    Boolean   @default(false)
  language    String    @default("en")
  lowBalanceSince DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  orders          Order[]
  deposits        Deposit[]
  subscriptions   NotificationSubscription[]
  autoReserves    AutoReserveSubscription[]
}

model Order {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  serviceId   String   // The pid (Project ID from Durian)
  countryId   String   // The cuy (Country Code from Durian)
  phoneNumber String
  price       Float    // How much the user was charged
  status      String   @default("PENDING") // PENDING, COMPLETED, CANCELLED
  smsCode     String?  // The received SMS code
  serial      String?  // Durian serial (1 or 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Deposit {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  amount      Float
  method      String   // e.g. 'MANUAL', 'CRYPTO'
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  transactionId String?  @unique
  createdAt   DateTime @default(now())
}

model CountryConfig {
  id          Int      @id @default(autoincrement())
  countryCode String   @unique
  isEnabled   Boolean  @default(true)
  price       Float    @default(0.25)
  updatedAt   DateTime @updatedAt
}
model GlobalSetting {
  key   String @id
  value String
}

model MandatoryChannel {
  id       Int    @id @default(autoincrement())
  username String @unique // e.g. @channelusername
  link     String        // e.g. https://t.me/channelusername
}

model NotificationSubscription {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  countryCode String
  createdAt   DateTime @default(now())

  @@unique([userId, countryCode])
}

model AutoReserveSubscription {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  countryCode String
  createdAt   DateTime @default(now())

  @@unique([userId, countryCode])
}
